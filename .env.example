# Network interface to bind for local development.
HOST=127.0.0.1

# Local API port for OpenAI-compatible and Ollama-compatible routes.
PORT=11424

# Backend implementation. Supported values: vllm, ollama, mock.
# Use vllm for direct Hugging Face/vLLM serving, ollama to proxy a local Ollama daemon,
# and mock only for local tests or dry runs.
INFERENCE_BACKEND=vllm

# Shared fallback default model. This is used for the mock backend and as the
# fallback when a backend-specific default model is not configured.
# Must be present in MODEL_ALLOWLIST when it is the effective default.
DEFAULT_MODEL_ID=Qwen/Qwen3.5-27B

# Optional default model override used only when INFERENCE_BACKEND=vllm.
# Must be present in MODEL_ALLOWLIST when set. Leave empty to fall back to DEFAULT_MODEL_ID.
VLLM_DEFAULT_MODEL_ID=Qwen/Qwen3.5-27B

# Optional default model override used only when INFERENCE_BACKEND=ollama.
# Must be present in MODEL_ALLOWLIST when set. Leave empty to fall back to DEFAULT_MODEL_ID.
OLLAMA_DEFAULT_MODEL_ID=gpt-oss:120b

# Comma-separated list of allowed model IDs developers may request.
MODEL_ALLOWLIST=Qwen/Qwen3.5-27B,Qwen/Qwen3-8B,Qwen/Qwen2.5-7B-Instruct,gpt-oss:120b

# Comma-separated subset of MODEL_ALLOWLIST that may be used with reasoning_effort.
# For Qwen/Qwen3.5-27B on the local vLLM backend, any reasoning_effort value enables
# thinking mode; the low/medium/high tiers are accepted for API compatibility but
# currently share the same backend behavior.
REASONING_MODEL_ALLOWLIST=Qwen/Qwen3.5-27B,Qwen/Qwen3-8B

# Global toggle for Qwen thinking mode. When false (default), the chat template
# always receives enable_thinking=False regardless of reasoning_effort in the request.
# When true, requests with reasoning_effort set will activate thinking mode.
ENABLE_THINKING=false

# Maximum number of interactive prompt executions allowed in parallel.
# This is the foreground semaphore in front of vLLM's continuous batcher.
# 16 is a conservative first jump from 8; 32 lets vLLM batch much more aggressively.
# Keep PROMPT_MAX_PARALLEL + BATCH_MAX_PARALLEL <= VLLM_MAX_NUM_SEQS.
PROMPT_MAX_PARALLEL=32

# Maximum number of batch item executions allowed in parallel.
# Recommended range: 4-8 for Qwen3.5-27B on 2 GPUs.
BATCH_MAX_PARALLEL=8

# Number of extra interactive requests that may wait in queue before 429 is returned.
FOREGROUND_QUEUE_LIMIT=32

# Number of extra batch items that may wait in queue before batch creation is rejected.
BATCH_QUEUE_LIMIT=128

# Maximum accepted input token estimate for a single request.
MAX_INPUT_TOKENS=4096

# Maximum accepted output token limit for a single request.
MAX_OUTPUT_TOKENS=1024

# Default temperature applied when the client does not provide one.
DEFAULT_TEMPERATURE=0.2

# Default top-p applied when the client does not provide one.
DEFAULT_TOP_P=0.95

# Root directory where uploaded files, batch metadata, and outputs are stored.
STORAGE_ROOT=data/runtime

# Repo-local directory where Hugging Face / vLLM model downloads and caches are stored.
# This keeps model weights out of the global user cache by default. Ignored when INFERENCE_BACKEND=ollama.
MODEL_CACHE_DIR=data/models

# Timeout in seconds for a foreground inference request.
REQUEST_TIMEOUT_SECONDS=120

# Timeout in seconds for model switching and warmup.
# In ollama mode, this also bounds upstream pulls triggered through /api/pull.
SWITCH_TIMEOUT_SECONDS=600

# Base URL for the upstream Ollama server used when INFERENCE_BACKEND=ollama.
# llm-serve does not start Ollama for you; it only proxies to this server.
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Base upstream timeout in seconds for Ollama inference requests.
# This is used only when INFERENCE_BACKEND=ollama.
OLLAMA_REQUEST_TIMEOUT_SECONDS=120

# When true, non-batch Ollama requests get one longer retry if the first upstream attempt times out.
# This is used only when INFERENCE_BACKEND=ollama.
OLLAMA_REQUEST_TIMEOUT_RETRY_ENABLED=true

# Multiplier applied to OLLAMA_REQUEST_TIMEOUT_SECONDS for the one retry attempt on direct Ollama requests.
# This is used only when INFERENCE_BACKEND=ollama.
OLLAMA_REQUEST_TIMEOUT_RETRY_MULTIPLIER=2.0

# When true, timed-out Ollama batch items are retried once after the first batch pass completes.
# This is used only when INFERENCE_BACKEND=ollama.
OLLAMA_BATCH_TIMEOUT_RETRY_ENABLED=true

# Multiplier applied to the base Ollama timeout during the batch retry pass.
# This is used only when INFERENCE_BACKEND=ollama.
OLLAMA_BATCH_TIMEOUT_RETRY_MULTIPLIER=2.0

# Multiplier applied to a timed-out batch item's requested output-token limit during the retry pass.
# This is used only when INFERENCE_BACKEND=ollama.
OLLAMA_BATCH_RETRY_OUTPUT_TOKENS_MULTIPLIER=2.0

# Maximum output-token limit llm-serve may use internally for the Ollama batch retry pass.
# This can exceed MAX_OUTPUT_TOKENS because it is an internal retry control, not a public request limit.
# This is used only when INFERENCE_BACKEND=ollama.
OLLAMA_BATCH_RETRY_MAX_OUTPUT_TOKENS=2048

# Whether to load the effective backend-specific default model during startup.
# Supported values: true, false.
STARTUP_LOAD_DEFAULT_MODEL=true

# When true, run a startup self-test prompt after the default model is loaded.
STARTUP_SELF_TEST_ENABLED=true

# When true, startup waits for the self-test to finish before the API is marked ready.
# When false, the self-test runs in the background and its status is exposed in /healthz.
# In blocking mode, a self-test failure fails startup. In background mode, the server stays up and reports failure in /healthz.
STARTUP_SELF_TEST_BLOCKING=false

# Prompt used for the startup self-test. This is useful for warming the model
# and checking that real generation works before the server is marked ready.
STARTUP_SELF_TEST_PROMPT=Write a thousand word poem about dawn breaking over mountains.

# Output token cap for the startup self-test. This must not exceed MAX_OUTPUT_TOKENS.
STARTUP_SELF_TEST_MAX_OUTPUT_TOKENS=1024

# When true, run a concurrency throughput sweep after the self-test completes.
# The sweep uses sparse levels (2, 4, 8, 16, 24, 32) capped at min(STARTUP_CONCURRENCY_TEST_MAX_LEVEL, PROMPT_MAX_PARALLEL).
# It blocks startup until done and uses the same prompt as the self-test, sending requests
# through the foreground lane like real interactive traffic.
STARTUP_CONCURRENCY_TEST=true

# Upper bound on the levels swept by the startup concurrency test.
# Must be at least 2. The actual top level is min(this, PROMPT_MAX_PARALLEL).
STARTUP_CONCURRENCY_TEST_MAX_LEVEL=32

# When true, the first vLLM model load inspects all host GPUs with nvidia-smi,
# chooses the best VLLM_GPU_COUNT GPUs by free memory, and sets CUDA_VISIBLE_DEVICES automatically.
# Ignored when INFERENCE_BACKEND=ollama or INFERENCE_BACKEND=mock.
VLLM_GPU_AUTO_SELECT=true

# Optional fixed CUDA device filter. This is only used directly when VLLM_GPU_AUTO_SELECT=false.
# Use GPU indices or UUIDs separated by commas, for example: 0,1 or GPU-abc,GPU-def
# Ignored when INFERENCE_BACKEND=ollama or INFERENCE_BACKEND=mock.
CUDA_VISIBLE_DEVICES=

# Number of visible GPUs vLLM should use for tensor parallelism.
# This maps directly to vLLM tensor_parallel_size, so it must be compatible
# with the selected model's tensor-parallel dimensions. More GPUs is not always valid.
# Ignored when INFERENCE_BACKEND=ollama or INFERENCE_BACKEND=mock.
VLLM_GPU_COUNT=2

# vLLM dtype override. Using bfloat16 is optimal for Qwen3.5-27B speed.
# Ignored when INFERENCE_BACKEND=ollama or INFERENCE_BACKEND=mock.
VLLM_DTYPE=bfloat16

# vLLM tokenizer mode. Typical values: auto, slow.
# Ignored when INFERENCE_BACKEND=ollama or INFERENCE_BACKEND=mock.
VLLM_TOKENIZER_MODE=auto

# Whether vLLM may execute remote model code. Supported values: true, false.
# Ignored when INFERENCE_BACKEND=ollama or INFERENCE_BACKEND=mock.
VLLM_TRUST_REMOTE_CODE=false

# When true, vLLM skips CUDA graph capture and runs in eager mode.
# This avoids hangs during startup on multi-GPU setups at the cost of slightly slower inference.
# Ignored when INFERENCE_BACKEND=ollama or INFERENCE_BACKEND=mock.
VLLM_ENFORCE_EAGER=true

# Use vLLM V1 engine (true) or V0 engine (false).
# V1 uses shared-memory IPC that can deadlock on multi-GPU setups.
# Default is false (V0) for stability. Set true only if V1 works on your hardware.
# Ignored when INFERENCE_BACKEND=ollama or INFERENCE_BACKEND=mock.
VLLM_USE_V1=false

# When true, load only the language model portion for multimodal checkpoints.
# This skips vision encoder loading and multimodal profiling, which is useful
# for text-only serving with Qwen3.5 on constrained multi-GPU setups.
VLLM_LANGUAGE_MODEL_ONLY=true

# Optional max context length passed directly to vLLM.
# For Qwen/Qwen3.5-27B on 2 GPUs, starting around 8192 is a practical throughput-oriented baseline.
# Raise it only if you need longer contexts and have verified memory headroom.
VLLM_MAX_MODEL_LEN=8192

# Optional GDN prefill backend passed directly to vLLM.
# Set to "triton" or "flashinfer", or leave empty to let vLLM decide.
VLLM_GDN_PREFILL_BACKEND=

# When true, pass vLLM disable_custom_all_reduce (often needed for stable multi-GPU runs).
VLLM_DISABLE_CUSTOM_ALL_REDUCE=true

# When true, vLLM caches KV blocks for shared prompt prefixes (system prompts, few-shot examples).
# Large throughput win when many requests share identical prefixes; small KV-cache memory overhead.
# Ignored when INFERENCE_BACKEND=ollama or INFERENCE_BACKEND=mock.
VLLM_ENABLE_PREFIX_CACHING=true

# When true, vLLM interleaves prefill with decode in the same scheduler step.
# This smooths GPU utilization under mixed traffic. Set false only if your vLLM build hits scheduler issues.
# Ignored when INFERENCE_BACKEND=ollama or INFERENCE_BACKEND=mock.
VLLM_ENABLE_CHUNKED_PREFILL=true

# Max sequences vLLM's continuous batcher will run at once.
# Should be >= PROMPT_MAX_PARALLEL + BATCH_MAX_PARALLEL or the server semaphore is the only limit.
# Ignored when INFERENCE_BACKEND=ollama or INFERENCE_BACKEND=mock.
VLLM_MAX_NUM_SEQS=64

# Max tokens per scheduler step. Larger improves prefill throughput but raises step latency.
# Must be >= VLLM_MAX_MODEL_LEN (enforced by validation).
# Ignored when INFERENCE_BACKEND=ollama or INFERENCE_BACKEND=mock.
VLLM_MAX_NUM_BATCHED_TOKENS=8192

# Optional CPU offload size (GiB) for KV cache.
# Helps under heavy concurrent load when GPU KV runs out. Leave empty to use vLLM default (4 GiB).
# Ignored when INFERENCE_BACKEND=ollama or INFERENCE_BACKEND=mock.
VLLM_SWAP_SPACE_GB=

# Preferred upper cap for vLLM gpu_memory_utilization. During adaptive startup,
# use this value when the chosen GPUs have enough free memory; otherwise derive a lower safe value.
# Ignored when INFERENCE_BACKEND=ollama or INFERENCE_BACKEND=mock.
VLLM_GPU_MEMORY_UTILIZATION=0.9

# Minimum allowed adaptive gpu_memory_utilization. If the best GPUs cannot meet at least this ratio,
# startup fails with an insufficient-memory error instead of overcommitting.
# Ignored when INFERENCE_BACKEND=ollama or INFERENCE_BACKEND=mock.
VLLM_GPU_MEMORY_UTILIZATION_MIN=0.5

# Fractional reserve to keep free on each selected GPU when deriving a safe utilization below the preferred cap.
# Ignored when INFERENCE_BACKEND=ollama or INFERENCE_BACKEND=mock.
VLLM_GPU_MEMORY_RESERVE_FRACTION=0.05

# Whether the mock backend should delay each response slightly for concurrency tests.
MOCK_RESPONSE_DELAY_SECONDS=0.0
